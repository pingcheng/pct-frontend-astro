---
import FixedWidthLayout from "@/layouts/FixedWidthLayout.astro";
import { Avatar } from "@/components/Avatar/Avatar";
import Heading from "@/components/Heading/Heading.astro";
import Chip from "@/components/Chip/Chip.astro";
import StructuredData from "@/components/StructuredData/StructuredData.astro";
import { profile, socialUrls } from "@/data/profile";
import {
    backendStack,
    devOpsStack,
    frontendStack,
    legacyStack,
} from "@/data/skills";
import { workExperiences } from "@/data/work-experience";
import { URLS } from "@/constants/urls";
import { getDurationString } from "@/utils/getDurationString";

// React Icons
import { FaLinkedin, FaGithub } from "react-icons/fa";
import { MdEmail, MdHistory } from "react-icons/md";
import { GrCode } from "react-icons/gr";
import { IoLogoJavascript } from "react-icons/io5";
import { FaCloud } from "react-icons/fa6";

const skillCategories = [
    { Icon: GrCode, title: "Backend", skills: backendStack },
    { Icon: IoLogoJavascript, title: "Frontend", skills: frontendStack },
    { Icon: FaCloud, title: "Cloud & DevOps", skills: devOpsStack },
    { Icon: MdHistory, title: "Legacy", skills: legacyStack },
];

const links = [
    {
        label: "github",
        url: socialUrls.github,
        text: "GitHub",
        ariaLabel: "Visit my GitHub profile",
        Icon: FaGithub,
    },
    {
        label: "linkedin",
        url: socialUrls.linkedin,
        text: "LinkedIn",
        ariaLabel: "Visit my LinkedIn profile",
        Icon: FaLinkedin,
    },
    {
        label: "email",
        url: `mailto:${profile.email}`,
        text: profile.email,
        ariaLabel: `Send email to ${profile.email}`,
        Icon: MdEmail,
    },
];

const allSkills = [
    ...backendStack,
    ...frontendStack,
    ...devOpsStack,
    ...legacyStack,
];
const breadcrumbItems = [
    { name: "Home", url: URLS.WEBSITE.BASE },
    { name: "About", url: URLS.WEBSITE.ABOUT },
];

function renderDescriptionLine(line: string) {
    if (line === ":line-break:") return { type: "break" as const };
    if (line.startsWith("- "))
        return { type: "bullet" as const, text: line.substring(2) };
    if (line.endsWith(":")) return { type: "heading" as const, text: line };
    return { type: "text" as const, text: line };
}
---

<FixedWidthLayout
    title="About Ping Cheng"
    description="Principal Engineer at REA Group with expertise in Node.js, TypeScript, PHP, Java, and Linux. Experienced in full-stack development, cloud solutions, and enterprise software."
    keywords="Ping Cheng,Principal Engineer,Software Engineer,Melbourne,Full Stack Developer,Cloud Engineer,REA Group,PropTrack,Node.js,TypeScript,PHP,Java,DevOps"
    ogTitle="About Ping Cheng"
    ogDescription="Principal Engineer at REA Group specializing in modern web technologies, cloud solutions, and enterprise software development."
    ogUrl="https://www.pingchengtech.com/about"
    ogType="profile"
    twitterCard="summary"
    twitterTitle="About Ping Cheng"
    twitterDescription="Principal Engineer at REA Group specializing in modern web technologies, cloud solutions, and enterprise software development."
>
    <StructuredData
        type="person"
        person={{
            name: profile.fullName,
            jobTitle: "Principal Engineer",
            url: URLS.WEBSITE.BASE,
            image: URLS.ASSETS.APPLE_ICON,
            sameAs: [socialUrls.github, socialUrls.linkedin],
            worksFor: { name: "REA Group", url: URLS.COMPANY.REA_GROUP },
            knowsAbout: allSkills,
            address: {
                addressLocality: "Melbourne",
                addressRegion: "Victoria",
                addressCountry: "Australia",
            },
            email: profile.email,
        }}
    />
    <StructuredData type="breadcrumb" breadcrumbItems={breadcrumbItems} />
    <StructuredData
        type="professionalService"
        professionalService={{
            name: "Software Development Services",
            description:
                "Full-stack web development, cloud solutions, and enterprise software development services specializing in Node.js, TypeScript, PHP, Java, and modern web technologies.",
            provider: { name: profile.fullName, url: URLS.WEBSITE.BASE },
            areaServed: "Melbourne, Australia",
            serviceType: "Software Development",
        }}
    />

    <main class="min-h-screen bg-transparent py-8">
        <div class="max-w-4xl mx-auto px-6">
            {/* Hero Section */}
            <section
                class="card p-8 rounded-lg w-full mb-8 animate-fade-in-scale"
            >
                <div class="flex flex-col lg:flex-row items-center gap-8">
                    <div
                        class="flex-shrink-0 animate-fade-in animate-delay-200"
                    >
                        <div class="shadow-lg" style="border-radius: 50%;">
                            <Avatar
                                width={120}
                                height={120}
                                alt="Ping Cheng profile photo"
                                client:load
                            />
                        </div>
                    </div>
                    <div class="flex-1 text-center lg:text-left">
                        <div class="mb-3 animate-fade-in animate-delay-300">
                            <Heading text="Ping Cheng" align="left" />
                        </div>
                        <h2
                            class="text-lg font-medium text-gray-800 dark:text-gray-200 mb-4 animate-fade-in animate-delay-400"
                        >
                            Principal Engineer at REA Group
                        </h2>
                        <p
                            class="text-gray-600 dark:text-gray-400 leading-relaxed mb-6 animate-fade-in animate-delay-500"
                        >
                            Experienced full-stack engineer specializing in
                            modern web technologies, cloud solutions, and
                            enterprise software development. Passionate about
                            building scalable systems and leading technical
                            initiatives that drive business value.
                        </p>
                        <div
                            class="flex flex-wrap gap-3 justify-center lg:justify-start animate-fade-in animate-delay-600"
                        >
                            {
                                links.map((link) => (
                                    <a
                                        href={link.url}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="inline-flex items-center gap-2 px-3 py-1.5 text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600 rounded-md hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors"
                                        aria-label={link.ariaLabel}
                                    >
                                        <link.Icon size={14} />
                                        <span class="text-xs">{link.text}</span>
                                    </a>
                                ))
                            }
                        </div>
                    </div>
                </div>
            </section>

            {/* Skills Section */}
            <section
                class="card p-6 rounded-lg w-full mb-8 animate-fade-in animate-delay-700"
            >
                <div class="mb-6 animate-fade-in animate-delay-800">
                    <Heading text="Technical Expertise" align="center" />
                </div>
                <div
                    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6"
                >
                    {
                        skillCategories.map((category) => (
                            <div>
                                <div class="text-center mb-3">
                                    <div class="w-10 h-10 bg-gray-100 dark:bg-gray-800 rounded-lg flex items-center justify-center mx-auto mb-2">
                                        <category.Icon
                                            className="text-base text-gray-600 dark:text-gray-400"
                                            aria-hidden="true"
                                        />
                                    </div>
                                    <h3 class="font-medium text-gray-900 dark:text-gray-100 text-sm">
                                        {category.title}
                                    </h3>
                                </div>
                                <div class="flex flex-wrap gap-2 justify-center">
                                    {category.skills.map((text) => (
                                        <Chip>{text}</Chip>
                                    ))}
                                </div>
                            </div>
                        ))
                    }
                </div>
            </section>

            {/* Experience Section */}
            <section
                class="card p-6 rounded-lg w-full animate-fade-in animate-delay-1300"
            >
                <div class="mb-6 animate-fade-in animate-delay-1400">
                    <Heading text="Professional Experience" align="center" />
                </div>
                <div class="space-y-6">
                    {
                        workExperiences.map((companyItem) => (
                            <div class="border-l-2 border-gray-200 dark:border-gray-700 pl-4">
                                <div class="mb-4">
                                    <div class="flex items-center gap-2 mb-1">
                                        <h3 class="text-base font-semibold text-gray-900 dark:text-gray-100">
                                            {companyItem.company.name}
                                        </h3>
                                        {companyItem.company.linkedInUrl && (
                                            <a
                                                href={
                                                    companyItem.company
                                                        .linkedInUrl
                                                }
                                                target="_blank"
                                                rel="noopener noreferrer"
                                                class="text-gray-500 hover:text-gray-700 dark:hover:text-gray-300 transition-colors"
                                                aria-label={`${companyItem.company.name} LinkedIn profile`}
                                            >
                                                <FaLinkedin
                                                    size={14}
                                                    aria-hidden="true"
                                                />
                                            </a>
                                        )}
                                    </div>

                                    <div class="space-y-3">
                                        {companyItem.positions.map((item) => (
                                            <div>
                                                <h4 class="font-medium text-gray-800 dark:text-gray-200 text-sm mb-1">
                                                    {item.position}
                                                </h4>
                                                <div class="text-xs text-gray-500 dark:text-gray-400 mb-2">
                                                    {item.startDate} -{" "}
                                                    {item.endDate} ·{" "}
                                                    {getDurationString(
                                                        item.startDate,
                                                        item.endDate
                                                    )}
                                                </div>
                                                {item.description.length >
                                                    0 && (
                                                    <div class="space-y-1">
                                                        {item.description.map(
                                                            (line) => {
                                                                const parsed =
                                                                    renderDescriptionLine(
                                                                        line
                                                                    );
                                                                if (
                                                                    parsed.type ===
                                                                    "break"
                                                                )
                                                                    return (
                                                                        <div class="h-1" />
                                                                    );
                                                                if (
                                                                    parsed.type ===
                                                                    "bullet"
                                                                )
                                                                    return (
                                                                        <div class="text-xs text-gray-600 dark:text-gray-400 leading-relaxed ml-3">
                                                                            •{" "}
                                                                            {
                                                                                parsed.text
                                                                            }
                                                                        </div>
                                                                    );
                                                                if (
                                                                    parsed.type ===
                                                                    "heading"
                                                                )
                                                                    return (
                                                                        <div class="text-xs font-medium text-gray-700 dark:text-gray-300 mt-2 mb-1">
                                                                            {
                                                                                parsed.text
                                                                            }
                                                                        </div>
                                                                    );
                                                                return (
                                                                    <div class="text-xs text-gray-600 dark:text-gray-400 leading-relaxed">
                                                                        {
                                                                            parsed.text
                                                                        }
                                                                    </div>
                                                                );
                                                            }
                                                        )}
                                                    </div>
                                                )}
                                            </div>
                                        ))}
                                    </div>
                                </div>
                            </div>
                        ))
                    }
                </div>
            </section>
        </div>
    </main>
</FixedWidthLayout>
